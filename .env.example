# Application
TP_APP_NAME=TracePilot
TP_APP_VERSION=0.1.0
TP_DEBUG=True
TP_LOG_LEVEL=info

# API
TP_API_V1_STR=/api/v1

# LLM Provider: openai, openai_compatible, ollama, groq, together, vllm, anthropic, google
TP_LLM_PROVIDER=openai

# Observability Provider: langfuse, langsmith, phoenix, none
TP_OBSERVABILITY_PROVIDER=langfuse

# Database (optional for local dev without persistence)
TP_DATABASE_URL=postgresql+asyncpg://tracepilot:tracepilot@localhost:5432/tracepilot

# Redis
TP_REDIS_URL=redis://localhost:6379/0

# --- OpenAI-compatible API (OpenAI, Groq, Ollama, vLLM, LiteLLM, etc.) ---
TP_OPENAI_API_KEY=ollama
TP_OPENAI_BASE_URL=http://localhost:11434/v1
TP_OPENAI_MODEL=qwen3:4b
TP_OPENAI_TEMPERATURE=0.7

# Ollama-specific (optional, used when LLM_PROVIDER=ollama)
TP_OLLAMA_BASE_URL=http://localhost:11434
TP_OLLAMA_MODEL=qwen3:4b
TP_OLLAMA_NUM_CTX=2048
TP_OLLAMA_NUM_GPU=1
TP_OLLAMA_KEEP_ALIVE=5m

# Groq-specific (optional, used when LLM_PROVIDER=groq)
# TP_OPENAI_API_KEY=gsk_...
# TP_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# TP_OPENAI_MODEL=llama-3.3-70b-versatile

# OpenAI-specific (optional, used when LLM_PROVIDER=openai)
# TP_OPENAI_API_KEY=sk-...
# TP_OPENAI_BASE_URL=https://api.openai.com/v1
# TP_OPENAI_MODEL=gpt-4o

# Anthropic/Claude (optional, used when LLM_PROVIDER=anthropic)
# TP_ANTHROPIC_API_KEY=sk-ant-...
# TP_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google/Gemini (optional, used when LLM_PROVIDER=google)
# TP_GOOGLE_API_KEY=...
# TP_GOOGLE_MODEL=gemini-2.0-flash

# Langfuse (self-hosted via docker-compose, or cloud)
TP_LANGFUSE_PUBLIC_KEY=pk-local-0000000000000000
TP_LANGFUSE_SECRET_KEY=sk-local-0000000000000000
TP_LANGFUSE_BASE_URL=http://localhost:3000
TP_LANGFUSE_FLUSH_AT=15
TP_LANGFUSE_FLUSH_INTERVAL=1

# Celery
TP_CELERY_BROKER_URL=redis://localhost:6379/0
TP_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# GitHub (for canary issues)
TP_GITHUB_TOKEN=ghp-your-github-token
TP_GITHUB_REPO=your-username/tracepilot

# Fuzzer
TP_FUZZER_DEFAULT_COUNT=10
TP_FUZZER_DETECTION_THRESHOLD=0.7

# Cleanup
TP_CLEANUP_RETENTION_DAYS=1
TP_CLEANUP_BATCH_SIZE=500

# Canary
TP_CANARY_THRESHOLD=0.15
TP_CANARY_CANDIDATES_DIR=canary/candidates
