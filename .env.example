# Application
APP_NAME=TracePilot
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=info

# API
API_V1_STR=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://tracepilot:tracepilot@localhost:5432/tracepilot

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI-compatible API (works with OpenAI, Groq, Ollama, vLLM, etc.)
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.1:8b
OPENAI_TEMPERATURE=0.7

# Langfuse (self-hosted via docker-compose, or cloud)
LANGFUSE_PUBLIC_KEY=pk-local-0000000000000000
LANGFUSE_SECRET_KEY=sk-local-0000000000000000
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_FLUSH_AT=15
LANGFUSE_FLUSH_INTERVAL=1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# GitHub (for canary issues)
GITHUB_TOKEN=ghp-your-github-token
GITHUB_REPO=your-username/tracepilot

# Fuzzer
FUZZER_DEFAULT_COUNT=10
FUZZER_DETECTION_THRESHOLD=0.7

# Canary
CANARY_THRESHOLD=0.15
CANARY_CANDIDATES_DIR=canary/candidates
